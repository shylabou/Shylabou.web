<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Productos | SHYLABOU</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400&display=swap" rel="stylesheet">
    <style>
        body { margin: 0; font-family: 'Montserrat', sans-serif; background: white; color: #000; }
        header { padding: 20px; border-bottom: 1px solid #eee; text-align: center; position: sticky; top: 0; background: white; z-index: 10; }
        .logo { text-decoration: none; color: black; font-weight: 500; letter-spacing: 4px; text-transform: uppercase; font-size: 18px; }
        h1 { text-transform: uppercase; letter-spacing: 3px; font-size: 14px; margin: 30px 0; text-align: center; font-weight: 400; }
        .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; padding: 15px; max-width: 1000px; margin: 0 auto; }
        .item { text-align: center; }
        .item img { width: 100%; aspect-ratio: 1/1; object-fit: cover; background: #f9f9f9; }
        .item-name { font-size: 11px; margin-top: 10px; text-transform: uppercase; letter-spacing: 1px; }
        .item-price { font-size: 12px; font-weight: 500; margin: 5px 0; }
        .buy-btn { display: block; width: 100%; border: 1px solid #000; padding: 8px 0; font-size: 9px; text-transform: uppercase; letter-spacing: 1px; text-decoration: none; color: black; }
        .back-link { display: block; text-align: center; margin: 40px 0; font-size: 11px; color: #888; text-decoration: none; text-transform: uppercase; }
    </style>
</head>
<body>

    <header>
        <a href="index.html" class="logo">SHYLABOU</a>
    </header>

    <h1>Nuestra Colección</h1>

    <div class="grid">
        <div class="item">
            <img src="IMG_5830.jpeg" alt="Producto">
            <div class="item-name">Gloss Essentials</div>
            <div class="item-price">$15.00 USD</div>
            <a href="https://wa.me/584128624428" class="buy-btn">Consultar</a>
        </div>

        <div class="item">
            <img src="IMG_8105.jpeg" alt="Producto">
            <div class="item-name">Shine Collection</div>
            <div class="item-price">$18.00 USD</div>
            <a href="https://wa.me/584128624428" class="buy-btn">Consultar</a>
        </div>

        <div class="item">
            <img src="IMG_8803.jpeg" alt="Producto">
            <div class="item-name">Soft Matte</div>
            <div class="item-price">$12.00 USD</div>
            <a href="https://wa.me/584128624428" class="buy-btn">Consultar</a>
        </div>

        <div class="item">
            <img src="IMG_8875.jpeg" alt="Producto">
            <div class="item-name">Crystal Lip</div>
            <div class="item-price">$20.00 USD</div>
            <a href="https://wa.me/584128624428" class="buy-btn">Consultar</a>
        </div>
    </div>

    <a href="index.html" class="back-link">← Volver al inicio</a>

</body>
</html>
